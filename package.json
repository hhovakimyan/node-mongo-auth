{
    "name": "node-mongo-auth",
    "version": "1.0.0",
    "description": "",
    "main": "src/index.ts",
    "type": "module",
    "scripts": {
        "start": "npx tsx --watch src/index.ts",
        "build": "tsc",
        "test": "echo \"Error: no test specified\" && exit 1",
        "lint": "eslint src",
        "format": "prettier --write src",
        "format:check": "prettier --check src",
        "prepare": "husky"
    },
    "imports": {
        "#controllers/*": {
            "default": "./src/controllers/*.ts"
        },
        "#middleware/*": {
            "default": "./src/middleware/*.ts"
        },
        "#repositories/*": {
            "default": "./src/repositories/*.ts"
        },
        "#types/*": {
            "default": "./src/types/*.ts"
        },
        "#validation/*": {
            "default": "./src/validation/*.ts"
        },
        "#integrations/*": {
            "default": "./src/integrations/*.ts"
        },
        "#dbSchemas/*": {
            "default": "./src/dbSchemas/*.ts"
        },
        "#routes/*": {
            "default": "./src/routes/*.ts"
        },
        "#services/*": {
            "default": "./src/services/*.ts"
        }
    },
    "private": true,
    "dependencies": {
        "bcrypt": "^6.0.0",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "jsonwebtoken": "^9.0.3",
        "mongoose": "^9.6.1",
        "redis": "^5.12.1",
        "yup": "^1.7.1"
    },
    "devDependencies": {
        "@tsconfig/node24": "^24.0.4",
        "@types/bcrypt": "^6.0.0",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/mongodb": "^4.0.6",
        "@types/node": "^25.6.0",
        "@types/redis": "^4.0.10",
        "eslint": "^10.3.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import-x": "^4.16.2",
        "eslint-plugin-unused-imports": "^4.4.1",
        "husky": "^9.1.7",
        "prettier": "^3.8.3",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.2"
    }
}
