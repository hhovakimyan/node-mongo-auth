{
    "name": "node-mongo-auth",
    "version": "1.0.0",
    "description": "",
    "main": "src/index.ts",
    "type": "module",
    "scripts": {
        "start": "npx tsx --watch src/index.ts",
        "build": "tsc",
        "test": "node --experimental-vm-modules node_modules/jest-cli/bin/jest.js",
        "test:watch": "node --experimental-vm-modules node_modules/jest-cli/bin/jest.js --watch",
        "lint": "eslint src/ tests/",
        "lint:fix": "eslint --fix src/ tests/",
        "format": "prettier --write \"{src,tests}/**/*.ts\"",
        "format:check": "prettier --check \"{src,tests}/**/*.ts\"",
        "test:all": "npm run test && npm run build"
    },
    "imports": {
        "#controllers/*": {
            "default": "./src/controllers/*.ts"
        },
        "#middleware/*": {
            "default": "./src/middleware/*.ts"
        },
        "#repositories/*": {
            "default": "./src/repositories/*.ts"
        },
        "#types/*": {
            "default": "./src/types/*.ts"
        },
        "#validation/*": {
            "default": "./src/validation/*.ts"
        },
        "#integrations/*": {
            "default": "./src/integrations/*.ts"
        },
        "#dbSchemas/*": {
            "default": "./src/dbSchemas/*.ts"
        },
        "#routes/*": {
            "default": "./src/routes/*.ts"
        },
        "#services/*": {
            "default": "./src/services/*.ts"
        },
        "#utils/*": {
            "default": "./src/utils/*.ts"
        },
        "#bootstrap/*": {
            "default": "./src/bootstrap/*.ts"
        }
    },
    "private": true,
    "dependencies": {
        "awilix": "^13.0.3",
        "awilix-express": "^11.0.1",
        "bcrypt": "^6.0.0",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "jsonwebtoken": "^9.0.3",
        "mongoose": "^9.6.1",
        "redis": "^5.12.1",
        "yup": "^1.7.1"
    },
    "devDependencies": {
        "@tsconfig/node24": "^24.0.4",
        "@types/bcrypt": "^6.0.0",
        "@types/express": "^5.0.6",
        "@types/jest": "^29.5.14",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/mongodb": "^4.0.6",
        "@types/node": "^25.6.0",
        "@types/redis": "^4.0.10",
        "@types/supertest": "^7.2.0",
        "eslint": "^10.3.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import-x": "^4.16.2",
        "eslint-plugin-unused-imports": "^4.4.1",
        "husky": "^9.1.7",
        "jest": "^29.7.0",
        "jest-util": "^30.4.1",
        "prettier": "^3.8.3",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.11",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.2"
    }
}
