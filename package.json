{
  "name": "node-mongo-auth",
  "version": "1.0.0",
  "description": "",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "start": "npx tsx --watch src/index.ts",
    "build": "tsc",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint src"
  },
  "imports": {
    "#controllers/*": {
      "default": "./src/controllers/*.ts"
    },
    "#middleware/*": {
      "default": "./src/middleware/*.ts"
    },
    "#repositories/*": {
      "default": "./src/repositories/*.ts"
    },
    "#types/*": {
      "default": "./src/types/*.ts"
    },
    "#validation/*": {
      "default": "./src/validation/*.ts"
    },
    "#integrations/*": {
      "default": "./src/integrations/*.ts"
    },
    "#dbSchemas/*": {
      "default": "./src/dbSchemas/*.ts"
    },
    "#routes/*": {
      "default": "./src/routes/*.ts"
    }
  },
  "private": true,
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "mongoose": "^9.6.1",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/express": "^5.0.6",
    "@types/mongodb": "^4.0.6",
    "@types/node": "^25.6.0",
    "eslint": "^10.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  }
}
